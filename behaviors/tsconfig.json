{
  "extends": "../tsconfig.common.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "./",
    "noUncheckedSideEffectImports": false,
    "paths": {
      "@server/*": [
        "../src/server/*"
      ],
      "@store/*": [
        "../src/store/*"
      ],
      "@view/*": [
        "../src/view/*"
      ]
    },
  },
  "include": [
    "./**/*"
  ],
  "references": [
    { "path": "../" }
  ]
}